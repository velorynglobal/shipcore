# ============================================================
# ShipCore - Environment Variables
# Copy this to .env.local and fill in values
# NEVER commit .env.local to version control
# ============================================================

# Supabase Configuration (Required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ShipCore
NEXT_PUBLIC_APP_VERSION=1.0.0

# Email (Resend or SMTP)
RESEND_API_KEY=re_your_resend_api_key

# WhatsApp (optional - via Twilio or WATI)
WHATSAPP_API_URL=https://api.wati.io/v1
WHATSAPP_API_TOKEN=your-whatsapp-token

# Storage (for file uploads)
NEXT_PUBLIC_STORAGE_BUCKET=shipcore-docs

# Feature Flags
NEXT_PUBLIC_ENABLE_WHATSAPP=false
NEXT_PUBLIC_ENABLE_EMAIL=true
